# Discord bot token from the Discord Developer Portal
TOKEN=your_discord_bot_token
PREFIX=!

# AI provider: openai or google
AI_PROVIDER=google

# Model for the selected provider
AI_MODEL=gemini-2.0-flash

# OpenAI API key (required when AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key

# Google Gemini API key (required when AI_PROVIDER=google)
GOOGLE_API_KEY=your_google_api_key

# Optional prompt style prepended to the chat context
STYLE=

# Database backend: mysql or sqlite
DB_TYPE=sqlite

# SQLite database path (used when DB_TYPE=sqlite)
SQLITE_PATH=data/bot.sqlite

# MySQL settings (used when DB_TYPE=mysql)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_mysql_user
# DB_PASSWORD=your_mysql_password
# DB_NAME=your_database
